                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <button type="button" class="btn btn-primary" onclick="saveProject()">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="closeProjectModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Certificate Modal -->
    <div id="certificateModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; padding-top: 50px;">
        <div class="modal-content" style="background: white; margin: auto; padding: 2rem; border-radius: 8px; width: 90%; max-width: 500px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <span class="close" onclick="closeCertificateModal()" style="float: right; font-size: 2rem; cursor: pointer;">&times;</span>
            <h2 id="certificateModalTitle">Add Certificate</h2>
            <form id="certificateForm" style="display: grid; gap: 1rem;">
                <input type="text" id="certTitle" placeholder="Certificate Title" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="certIssuer" placeholder="Issued By" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="date" id="certDate" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="url" id="certUrl" placeholder="Certificate URL" style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <textarea id="certDescription" placeholder="Description" rows="4" style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;"></textarea>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <button type="button" class="btn btn-primary" onclick="saveCertificate()">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="closeCertificateModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Skill Modal -->
    <div id="skillModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; padding-top: 50px;">
        <div class="modal-content" style="background: white; margin: auto; padding: 2rem; border-radius: 8px; width: 90%; max-width: 500px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <span class="close" onclick="closeSkillModal()" style="float: right; font-size: 2rem; cursor: pointer;">&times;</span>
            <h2 id="skillModalTitle">Add Skill</h2>
            <form id="skillForm" style="display: grid; gap: 1rem;">
                <input type="text" id="skillName" placeholder="Skill Name" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="skillIcon" placeholder="Icon (FontAwesome class, e.g., fas fa-code)" style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <button type="button" class="btn btn-primary" onclick="saveSkill()">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="closeSkillModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Testimonial Modal -->
    <div id="testimonialModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; padding-top: 50px;">
        <div class="modal-content" style="background: white; margin: auto; padding: 2rem; border-radius: 8px; width: 90%; max-width: 500px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <span class="close" onclick="closeTestimonialModal()" style="float: right; font-size: 2rem; cursor: pointer;">&times;</span>
            <h2 id="testimonialModalTitle">Add Testimonial</h2>
            <form id="testimonialForm" style="display: grid; gap: 1rem;">
                <input type="text" id="testName" placeholder="Author Name" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="testTitle" placeholder="Author Title" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <textarea id="testContent" placeholder="Testimonial Content" rows="4" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;"></textarea>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" id="testApproved" style="width: 18px; height: 18px; cursor: pointer;">
                    <span>Approved</span>
                </label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <button type="button" class="btn btn-primary" onclick="saveTestimonial()">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="closeTestimonialModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Experience Modal -->
    <div id="experienceModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; padding-top: 50px;">
        <div class="modal-content" style="background: white; margin: auto; padding: 2rem; border-radius: 8px; width: 90%; max-width: 500px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <span class="close" onclick="closeExperienceModal()" style="float: right; font-size: 2rem; cursor: pointer;">&times;</span>
            <h2 id="experienceModalTitle">Add Experience</h2>
            <form id="experienceForm" style="display: grid; gap: 1rem;">
                <input type="text" id="expCompanyName" placeholder="Company Name" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="expPosition" placeholder="Position" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="expDuration" placeholder="Duration (e.g., 1.5 years)" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="url" id="expCompanyUrl" placeholder="Company Website URL" style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <input type="text" id="expCompanyType" placeholder="Company Type (e.g., Product Based)" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <textarea id="expDescription" placeholder="Description" rows="4" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;"></textarea>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <input type="date" id="expStartDate" required style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                    <input type="date" id="expEndDate" style="padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <button type="button" class="btn btn-primary" onclick="saveExperience()">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="closeExperienceModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
