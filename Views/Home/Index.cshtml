@model DashboardViewModel
@{
    ViewData["Title"] = "Kavin Kumar - Web Full Stack Developer";
}

<style>
    /* DEVELOPER STUDIO HERO */
    .hero-studio {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.1) 0%, transparent 40%),
                    radial-gradient(circle at 10% 80%, rgba(236, 72, 153, 0.05) 0%, transparent 40%);
        position: relative;
        overflow: hidden;
    }

    .studio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 2rem;
        align-items: center;
        z-index: 10;
    }

    .studio-info h2 {
        font-size: clamp(1.5rem, 3vw, 2.2rem);
        color: var(--text-primary);
        font-weight: 500;
        margin-bottom: 1rem;
    }

    .studio-info h1 {
        font-size: clamp(3rem, 7vw, 4.5rem);
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--text-primary);
    }

    .name-accent {
        color: var(--primary);
        position: relative;
    }

    .role-text {
        color: var(--secondary);
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        font-weight: 800;
        margin-bottom: 2.5rem;
    }

    .social-row {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 3.5rem;
    }

    .social-btn {
        width: 48px;
        height: 48px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-primary);
        font-size: 1.25rem;
        transition: var(--transition);
        text-decoration: none;
    }

    .social-btn:hover {
        background: var(--primary);
        color: #fff;
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
    }

    /* CODE TERMINAL WIDGET */
    .terminal-widget {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
        overflow: hidden;
        font-family: 'Fira Code', 'Consolas', monospace;
        position: relative;
    }

    .terminal-header {
        background: rgba(255,255,255,0.05);
        padding: 0.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot-red { background: #ff5f56; }
    .dot-yellow { background: #ffbd2e; }
    .dot-green { background: #27c93f; }

    .terminal-body {
        padding: 2rem;
        font-size: 0.95rem;
        line-height: 1.7;
        color: #94a3b8;
    }

    .code-comment { color: #64748b; font-style: italic; }
    .code-keyword { color: #f472b6; }
    .code-string { color: #10b981; }
    .code-property { color: #7dd3fc; }
    .code-value { color: #fbbf24; }

    .btn-studio-group {
        display: flex;
        gap: 1.5rem;
    }

    @@media (max-width: 968px) {
        .studio-container {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .social-row, .btn-studio-group {
            justify-content: center;
        }
    }
</style>

<div class="hero-studio">
    <div class="studio-container">
        <!-- Left Side: Profile Info -->
        <div class="studio-info fade-up">
            <h2>Hello,</h2>
            <h1>This is <span class="name-accent">KAVIN KUMAR</span>,<br/>
            I'm a <span class="role-text">Professional .NET Developer.</span></h1>
        </div>

        <!-- Right Side: Code Terminal -->
        <div class="terminal-wrap slide-right">
            <div class="terminal-widget">
                <div class="terminal-header">
                    <div class="dot dot-red"></div>
                    <div class="dot dot-yellow"></div>
                    <div class="dot dot-green"></div>
                    <span style="color: #64748b; font-size: 0.8rem; margin-left: 10px;">DeveloperProfile.cs</span>
                </div>
                <div class="terminal-body">
                    <span class="code-keyword">public class</span> <span class="code-property">KavinKumar</span> {<br/>
                    &nbsp;&nbsp;<span class="code-keyword">string</span> <span class="code-property">Role</span> = <span class="code-string">"Full Stack Developer"</span>;<br/>
                    &nbsp;&nbsp;<span class="code-keyword">string[]</span> <span class="code-property">CoreStack</span> = { <span class="code-string">".NET 8"</span>, <span class="code-string">"React"</span>, <span class="code-string">"SQL"</span> };<br/>
                    &nbsp;&nbsp;<span class="code-keyword">bool</span> <span class="code-property">HardWorker</span> = <span class="code-keyword">true</span>;<br/>
                    &nbsp;&nbsp;<span class="code-keyword">bool</span> <span class="code-property">ExpertLearner</span> = <span class="code-keyword">true</span>;<br/>
                    &nbsp;&nbsp;<span class="code-keyword">bool</span> <span class="code-property">ProblemSolver</span> = <span class="code-keyword">true</span>;<br/>
                    &nbsp;&nbsp;<br/>
                    &nbsp;&nbsp;<span class="code-keyword">public string</span> <span class="code-property">Hireable</span>() {<br/>
                    &nbsp;&nbsp;&nbsp;&nbsp;<span class="code-keyword">return</span> <span class="code-property">HardWorker</span> && <span class="code-property">ProblemSolver</span> && <br/>
                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="code-property">CoreStack</span>.<span class="code-property">Length</span> >= <span class="code-value">3</span>;<br/>
                    &nbsp;&nbsp;}<br/>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- About Section -->
<section id="about" class="section">
    <h2 class="section-title fade-up">Technical Overview</h2>
    <p class="section-subtitle fade-up">My methodology and professional journey</p>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div class="slide-left">
            <h3 class="theme-heading" style="font-size: 1.8rem; margin-bottom: 1.5rem;">Bridging Logic with User Experience</h3>
            <p style="font-size: 1.1rem; line-height: 1.8; margin-bottom: 1.5rem; color: var(--text-secondary);">
                As a <strong style="color: var(--primary);">Web Full Stack Developer</strong>, I specialize in the end-to-end delivery of enterprise-grade applications. My expertise spans across the entire development lifecycle, from designing high-performance REST APIs with .NET Core to crafting responsive, state-managed React interfaces.
            </p>
            <p style="font-size: 1.1rem; line-height: 1.8; margin-bottom: 2rem; color: var(--text-secondary);">
                I am deeply committed to the principles of <strong style="color: var(--primary);">Clean Architecture</strong> and <strong style="color: var(--primary);">SOLID</strong>, ensuring that every line of code is maintainable, scalable, and efficient.
            </p>
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--primary); font-weight: 700;">
                    <i class="fas fa-check-circle"></i> API First Design
                </div>
                <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--primary); font-weight: 700;">
                    <i class="fas fa-check-circle"></i> Clean Code Standards
                </div>
                <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--primary); font-weight: 700;">
                    <i class="fas fa-check-circle"></i> Performance Focused
                </div>
            </div>
        </div>
        <div style="text-align: center;" class="slide-right">
            <div style="position: relative; width: 320px; height: 400px; margin: 0 auto;">
                <div style="position: absolute; inset: 0; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 24px; transform: rotate(-5deg); z-index: 1; opacity: 0.2; filter: blur(10px);"></div>
                <div style="position: absolute; inset: 0; background: var(--bg-card); border-radius: 24px; transform: rotate(5deg); z-index: 1; border: 1px solid var(--border); box-shadow: var(--shadow-lg);"></div>
                <img src="~/images/kavin.JPG" asp-append-version="true" alt="Kavin Kumar" style="position: relative; width: 100%; height: 100%; object-fit: cover; object-position: top; border-radius: 20px; z-index: 2; box-shadow: var(--shadow-md); filter: contrast(1.05);" />
            </div>
        </div>
    </div>
</section>

    @if (ViewBag.ShowMessage != null)
    {
        <div class="alert alert-info" style="margin-top: 2rem;">
            <i class="fas fa-info-circle"></i>
            <span>@ViewBag.ShowMessage</span>
        </div>
    }
</section>

<!-- Education Section -->
<section id="education" class="section" style="background: var(--bg-secondary);">
    <h2 class="section-title fade-up">Education</h2>
    <p class="section-subtitle fade-up">Academic background and qualifications</p>
    
    @if (Model?.Educations?.Count > 0)
    {
        <div class="card-grid">
            @foreach (var education in Model.Educations)
            {
                <div class="card fade-up futuristic-card" style="border-radius: 24px; padding: 2rem;">
                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1.5rem;">
                        <div style="width: 50px; height: 50px; background: rgba(99, 102, 241, 0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: var(--primary);">
                            <i class="fas fa-graduation-cap" style="font-size: 1.5rem;"></i>
                        </div>
                        @if (!string.IsNullOrEmpty(education.CGPA.ToString()))
                        {
                            <div style="background: rgba(16, 185, 129, 0.1); color: var(--success); padding: 0.4rem 1rem; border-radius: 100px; font-weight: 700; font-size: 0.85rem; border: 1px solid rgba(16, 185, 129, 0.2);">
                                @education.CGPA CGPA
                            </div>
                        }
                    </div>
                    
                    <h3 style="color: var(--text-primary); margin-bottom: 0.6rem; font-size: 1.4rem; font-weight: 800;">@education.Degree</h3>
                    <p style="font-weight: 600; color: var(--text-primary); margin-bottom: 1rem; font-size: 1rem;">@education.InstitutionName</p>
                    
                    <div style="display: flex; flex-direction: column; gap: 0.5rem; color: var(--text-secondary); font-size: 0.9rem;">
                        <div style="display: flex; align-items: center; gap: 0.6rem;">
                            <i class="fas fa-calendar" style="color: var(--primary); width: 16px;"></i>
                            <span>Class of @education.GraduationYear</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.6rem;">
                            <i class="fas fa-location-dot" style="color: var(--primary); width: 16px;"></i>
                            <span>@education.Location</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</section>

<!-- Projects Section -->
<section id="projects" class="section">
    <h2 class="section-title fade-up">Systems & Architecture</h2>
    <p class="section-subtitle fade-up">A collection of professional deployments and academic engineering projects.</p>
    
    @if (Model?.Projects?.Count > 0)
    {
        <div class="card-grid">
            @foreach (var project in Model.Projects.OrderByDescending(p => p.Id))
            {
                <div class="card fade-up futuristic-card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column; border-radius: 24px;">
                    <div style="height: 220px; background: #0f172a; position: relative; overflow: hidden;">
                         <img src="/images/@project.ImageUrl" asp-append-version="true" alt="@project.Title" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7; transition: transform 0.6s ease;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'" onerror="this.src='/images/project-placeholder.jpg'">
                         <!-- Category Badge -->
                         <div style="position: absolute; top: 1rem; left: 1rem;">
                             <span style="background: @(project.Category == "Professional Work" ? "var(--primary)" : "var(--bg-secondary)"); backdrop-filter: blur(8px); color: @(project.Category == "Professional Work" ? "var(--text-on-dark)" : "var(--text-primary)"); padding: 0.5rem 1rem; border-radius: 10px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid var(--border);">
                                 @project.Category
                             </span>
                         </div>

                         <div style="position: absolute; bottom: 1rem; left: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
                             @foreach(var tech in (project.Technologies ?? "").Split(',')) {
                                 <span style="background: var(--bg-card); backdrop-filter: blur(8px); color: var(--text-primary); padding: 0.3rem 0.75rem; border-radius: 8px; font-size: 0.7rem; font-weight: 700; border: 1px solid var(--border);">@tech.Trim()</span>
                             }
                         </div>
                    </div>
                    <div style="padding: 1.75rem; flex: 1; display: flex; flex-direction: column;">
                        <h3 style="color: var(--text-primary); margin-bottom: 0.75rem; font-size: 1.3rem; font-weight: 700;">@project.Title</h3>
                        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem; flex: 1;">@project.Description</p>
                        
                        <div style="display: flex; gap: 1rem; margin-top: auto;">
                            @if (!string.IsNullOrEmpty(project.ProjectUrl) && project.ProjectUrl != "#")
                            {
                                <a href="@project.ProjectUrl" target="_blank" class="btn btn-primary btn-sm" style="flex: 1; justify-content: center; border-radius: 12px; font-weight: 700;">Live Demo <i class="fas fa-external-link-alt" style="margin-left: 6px;"></i></a>
                            }
                            @if (!string.IsNullOrEmpty(project.GithubUrl) && project.GithubUrl != "#")
                            {
                                <a href="@project.GithubUrl" target="_blank" class="btn btn-secondary btn-sm" style="flex: 1; justify-content: center; border-radius: 12px; font-weight: 700;"><i class="fab fa-github" style="margin-right: 6px;"></i> Code</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<!-- Experience Section -->
<section id="experience" class="section">
    <h2 class="section-title fade-up">Experience</h2>
    <p class="section-subtitle fade-up">My professional background and experience</p>
    
    @if (Model?.Experiences?.Count > 0)
    {
        <div style="position: relative; padding-left: 2rem;">
            <!-- Vertical Timeline Line -->
            <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%); border-radius: 3px; opacity: 0.3;"></div>
            
            <div style="display: grid; gap: 2.5rem;">
                @foreach (var exp in Model.Experiences.OrderByDescending(e => e.StartDate))
                {
                    <div class="card fade-up" @(!string.IsNullOrEmpty(exp.CompanyUrl) ? $"onclick=window.open('{exp.CompanyUrl}','_blank')" : "") style="position: relative; @(!string.IsNullOrEmpty(exp.CompanyUrl) ? "cursor: pointer;" : "")">
                        <!-- Timeline Dot -->
                        <div style="position: absolute; left: -2.35rem; top: 2rem; width: 14px; height: 14px; background: var(--primary); border-radius: 50%; box-shadow: 0 0 10px var(--primary);"></div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 1rem;">
                            <div>
                                <h3 style="margin: 0; font-size: 1.35rem; color: var(--text-primary);">@exp.Position</h3>
                                <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem;">
                                    <h4 style="color: var(--primary); margin: 0; font-weight: 700;">
                                        <i class="fas fa-building" style="font-size: 0.9rem; margin-right: 4px;"></i> @exp.CompanyName
                                    </h4>
                                    <span style="width: 4px; height: 4px; background: var(--text-secondary); border-radius: 50%; opacity: 0.4;"></span>
                                    <span style="color: var(--text-secondary); font-size: 0.9rem; font-weight: 600;">@exp.CompanyType</span>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <span style="background: rgba(99, 102, 241, 0.1); color: var(--primary); padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 700; border: 1px solid rgba(99, 102, 241, 0.2);">
                                    <i class="far fa-calendar-alt" style="margin-right: 6px;"></i> @exp.Duration
                                </span>
                                <div style="margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.8rem; font-weight: 500;">
                                    @exp.StartDate.ToString("MMM yyyy") — @(exp.EndDate?.ToString("MMM yyyy") ?? "Present")
                                </div>
                            </div>
                        </div>
                        
                        <div style="padding: 1.25rem; background: rgba(0,0,0,0.02); border-radius: 12px; border: 1px solid rgba(0,0,0,0.03);">
                             <p style="line-height: 1.7; color: var(--text-secondary); margin: 0; white-space: pre-line;">@exp.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</section>

<!-- Skills Section -->
<section id="skills" class="section">
    <h2 class="section-title fade-up">Core Expertise</h2>
    <p class="section-subtitle fade-up">Specialized in full-stack engineering and enterprise architecture</p>
    
    @if (Model?.Skills != null) {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2.5rem; margin-top: 3.5rem;">
            @foreach (var category in Model.Skills.GroupBy(s => s.Category))
            {
            <div class="card fade-up futuristic-card" style="padding: 2.75rem; border-radius: 32px; background: var(--bg-card);">
                <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2.5rem;">
                    <div style="width: 14px; height: 14px; background: var(--primary); border-radius: 50%; box-shadow: 0 0 15px var(--primary);"></div>
                    <h3 style="margin: 0; font-size: 1.6rem; font-weight: 800; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.1em;">@category.Key</h3>
                </div>
                
                <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
                    @foreach (var skill in category)
                    {
                        <div style="background: rgba(99, 102, 241, 0.08); border: 1px solid rgba(99, 102, 241, 0.15); padding: 0.85rem 1.4rem; border-radius: 16px; display: flex; align-items: center; gap: 1rem; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: default; backdrop-filter: blur(5px);" onmouseover="this.style.background='rgba(99, 102, 241, 0.18)'; this.style.borderColor='rgba(99, 102, 241, 0.5)'; this.style.transform='translateY(-5px) scale(1.05)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.2)'" onmouseout="this.style.background='rgba(99, 102, 241, 0.08)'; this.style.borderColor='rgba(99, 102, 241, 0.15)'; this.style.transform='translateY(0) scale(1)'; this.style.boxShadow='none'">
                            <i class="@skill.Icon" style="color: var(--primary); font-size: 1.2rem;"></i>
                            <span style="color: var(--text-primary); font-weight: 700; font-size: 1rem;">@skill.Name</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
</section>

<!-- Certificates Section -->
<section id="certificate" class="section">
    <h2 class="section-title fade-up">Certifications</h2>
    <p class="section-subtitle fade-up">Professional certifications and achievements</p>
    
    @if (Model?.Certificates?.Count > 0)
    {
        <div class="card-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
            @foreach (var cert in Model.Certificates.OrderByDescending(c => c.Id))
            {
                <div class="card scale-in futuristic-card" style="padding: 1.75rem; display: flex; flex-direction: column; justify-content: space-between; min-height: 240px; border-radius: 24px;">
                    <div>
                        <div style="display: flex; gap: 1rem; align-items: start; margin-bottom: 1.5rem;">
                             <div style="min-width: 50px; height: 50px; background: rgba(99, 102, 241, 0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: var(--primary);">
                                <i class="fas fa-award" style="font-size: 1.5rem;"></i>
                             </div>
                             <div>
                                 <h3 style="font-size: 1.15rem; margin: 0; line-height: 1.4; font-weight: 800; color: var(--text-primary);">@cert.Title</h3>
                                 <p style="font-size: 0.9rem; color: var(--primary); margin: 6px 0 0 0; font-weight: 700; letter-spacing: 0.5px;">@cert.IssuedBy</p>
                             </div>
                        </div>
                        <div style="font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.25rem; font-weight: 500;">
                            <i class="far fa-calendar-alt" style="color: var(--primary);"></i>
                            @cert.IssueDate.ToString("MMMM yyyy")
                        </div>
                    </div>
                    
                    <a href="@cert.CertificateUrl" target="_blank" class="btn btn-sm btn-outline btn-block" style="justify-content: center; font-size: 0.85rem; padding: 0.75rem; border-radius: 12px; font-weight: 700;">
                        <i class="fas fa-shield-check" style="margin-right: 8px;"></i> Verify Auth Credentials
                    </a>
                </div>
            }
        </div>
    }

</section>

<!-- Contact Section -->
<section id="contact" class="section" style="background: var(--bg-secondary);">
    <h2 class="section-title fade-up">Get In Touch</h2>
    <p class="section-subtitle fade-up">Have a question or want to work together?</p>
    
    @if (ViewBag.ContactSuccess != null || TempData["ContactSuccess"] != null)
    {
        <div class="alert alert-success" style="margin-bottom: 2rem;">
            <i class="fas fa-check-circle"></i>
            <span>@(ViewBag.ContactSuccess ?? TempData["ContactSuccess"])</span>
        </div>
    }

    @if (ViewBag.ContactError != null || TempData["ContactError"] != null)
    {
        <div class="alert alert-danger" style="margin-bottom: 2rem;">
            <i class="fas fa-exclamation-circle"></i>
            <span>@(ViewBag.ContactError ?? TempData["ContactError"])</span>
        </div>
    }

    <div style="max-width: 600px; margin: 0 auto;">
        <form id="contactForm" class="scale-in" style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="form-group">
                <label class="form-label">Your Name</label>
                <input type="text" id="contactName" class="form-input" placeholder="John Doe" required />
            </div>

            <div class="form-group">
                <label class="form-label">Your Email</label>
                <input type="email" id="contactEmail" class="form-input" placeholder="john@example.com" required />
            </div>

            <div class="form-group">
                <label class="form-label">Message</label>
                <textarea id="contactMessage" class="form-textarea" placeholder="Your message here..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">
                <i class="fas fa-paper-plane"></i> Send Message
            </button>
        </form>

        <script>
            document.getElementById('contactForm').addEventListener('submit', async function(e) {
                e.preventDefault();

                const name = document.getElementById('contactName').value;
                const email = document.getElementById('contactEmail').value;
                const message = document.getElementById('contactMessage').value;

                try {
                    const response = await fetch('/Contact/Send', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            name: name,
                            email: email,
                            message: message
                        })
                    });

                    if (response.ok) {
                        document.getElementById('contactName').value = '';
